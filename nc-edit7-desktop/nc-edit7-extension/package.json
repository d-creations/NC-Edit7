{
  "name": "nc-edit7-extension",
  "displayName": "NC-Edit7",
  "description": "Custom Editor for NC/MPF Files",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "ncEdit7.editor",
        "displayName": "NC-Edit7 Editor",
        "selector": [
          {
            "filenamePattern": "*.mpf"
          },
          {
            "filenamePattern": "*.nc"
          },
          {
            "filenamePattern": "*.P2"
          },
          {
            "filenamePattern": "*.P1"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.4"
  }
}
