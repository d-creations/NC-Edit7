{
  "name": "nc-edit7",
  "version": "0.1.0",
  "description": "Multi-channel CNC NC code editor with plot interface",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "build:desktop": "npm run build && cd nc-edit7-desktop && npm run build:electron",
    "prepare": "npm run build"
  },
  "files": [
      "dist",
      "package.json"
  ],
  "dependencies": {
    "ace-builds": "^1.43.4",
    "cnc7drawnccode": "git+https://github.com/d-creations/CNC7drawNCcode.git",
    "three": "^0.161.0"
  },
  "devDependencies": {    
    "@types/three": "^0.161.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vitest/ui": "^4.0.12",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.12",
    "vitest": "^4.0.12"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-creations/NC-Edit7.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/d-creations/NC-Edit7/issues"
  },
  "homepage": "https://github.com/d-creations/NC-Edit7#readme"
}
